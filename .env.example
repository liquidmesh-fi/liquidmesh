# OKX OnchainOS — 1 API key for all agents
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_PASSPHRASE=your_okx_passphrase

# Agent TEE sub-accounts (create 4 via OKX Agentic Wallet)
SCOUT_ACCOUNT_ID=
SCOUT_WALLET_ADDRESS=0x...
ANALYST_ACCOUNT_ID=
ANALYST_WALLET_ADDRESS=0x...
EXECUTOR_ACCOUNT_ID=
EXECUTOR_WALLET_ADDRESS=0x...
ORCHESTRATOR_ACCOUNT_ID=
ORCHESTRATOR_WALLET_ADDRESS=0x...

# OpenAI (for Analyst scoring)
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Runtime
PUBLIC_API_URL=http://localhost:3001        # backend URL (Railway URL in prod)
EXECUTOR_SWAP_AMOUNT_OKB=0.005             # OKB per swap (~$0.42 at $83/OKB)
CHECK_INTERVAL_MINUTES=30                  # agent tick interval
ENABLE_AGENTS=false                        # set true to auto-start on boot

